generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ActivityType {
  LOGIN
  HEALTH_SCORE
  FEEDBACK
  COMMISSION
  QR_CODE
  CHECKLIST
  REPORT
  PROFILE
  SETTINGS
}

model User {
  id                     String                 @id @default(cuid())
  name                   String
  email                  String                 @unique
  passwordHash           String
  role                   String                 @default("agent")
  notificationsEnabled   Boolean                @default(true)
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  properties             Property[]
  healthScores           PropertyHealthScore[]
  feedbackEntries        ViewingFeedback[]
  commissionCalculations CommissionCalculation[]
  qrCodes                QrCode[]
  checklists             MarketingChecklist[]
  vendorReports          VendorReport[]
  activities             Activity[]
}

model Property {
  id              String                 @id @default(cuid())
  userId          String
  title           String
  address         String?
  price           Float?
  status          String                 @default("Active")
  notes           String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  user            User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  healthScores    PropertyHealthScore[]
  feedbackEntries ViewingFeedback[]
  checklists      MarketingChecklist[]
  vendorReports   VendorReport[]
}

model PropertyHealthScore {
  id           String    @id @default(cuid())
  userId       String
  propertyId   String?
  propertyName String?
  inputs       Json
  score        Int
  suggestions  Json
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model ViewingFeedback {
  id             String    @id @default(cuid())
  userId         String
  propertyId     String?
  propertyName   String
  viewerName     String
  rating         Int
  liked          String
  disliked       String
  priceOpinion   String
  wouldRecommend Boolean
  interested     Boolean
  comments       String
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property       Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model CommissionCalculation {
  id               String   @id @default(cuid())
  userId           String
  propertyPrice    Float
  commissionPercent Float
  vatEnabled       Boolean
  commission       Float
  vat              Float
  total            Float
  net              Float
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QrCode {
  id          String   @id @default(cuid())
  userId      String
  propertyUrl String
  imageData   String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketingChecklist {
  id           String    @id @default(cuid())
  userId       String
  propertyId   String?
  propertyName String?
  title        String
  items        Json
  progress     Int
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property     Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model VendorReport {
  id                 String    @id @default(cuid())
  userId             String
  propertyId         String?
  propertyName       String
  marketingChecklist Json
  healthScore        Json
  feedbackSummary    Json
  offers             Json
  notes              String
  pdfFileName        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  property           Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
}

model Activity {
  id          String       @id @default(cuid())
  userId      String
  type        ActivityType
  title       String
  description String
  createdAt   DateTime     @default(now())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}